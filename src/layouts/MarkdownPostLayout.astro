---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
const hasImage = frontmatter.image ? true : false;

const imageUrl = frontmatter.image?.src.startsWith("http")
  ? frontmatter.image?.src
  : Astro.url.origin + frontmatter.image?.src;
---

<BaseLayout pageTitle={frontmatter.title}>
  <section>
    <div class="container">
      <p>Published on: {frontmatter.date.toLocaleDateString()}</p>
      <p><em>{frontmatter.description}</em></p>
      <p>Written by {frontmatter.author}</p>
      {
        hasImage && (
          <img
            src={imageUrl}
            width="300"
            alt={frontmatter.imageAlt}
          />
        )
      }
      <slot />
    </div>
  </section>
</BaseLayout>
