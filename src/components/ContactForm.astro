---
import { BUSINESS } from "@data/client";
---

<section class="contact">
  <div class="container">
    <div class="contact__main-content">
      <div class="section__title">
        <span class="topper">Get in Touch</span>
        <h2>Contact Us</h2>
      </div>
      <p class="contact__content">
        Send us an email to let us know what you want out of your site. We will
        respond within 24 hours. Feel free to give us a call to reach us
        immediately. If we are unavailable we will call back the same day.
      </p>
      <div class="contact__details">
        <a
          href={`mailto:${BUSINESS.email}`}
          class="contact__email"
        >
          <div class="icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <g
                id="SVGRepo_bgCarrier"
                stroke-width="0"
              >
              </g>
              <g
                id="SVGRepo_tracerCarrier"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
              </g>
              <g id="SVGRepo_iconCarrier">
                <path
                  d="M4 7.00005L10.2 11.65C11.2667 12.45 12.7333 12.45 13.8 11.65L20 7"
                  stroke="#4e4b66"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                </path>
                <rect
                  x="3"
                  y="5"
                  width="18"
                  height="14"
                  rx="2"
                  stroke="#4e4b66"
                  stroke-width="2"
                  stroke-linecap="round"
                >
                </rect>
              </g>
            </svg>
          </div>
          {BUSINESS.email}
        </a>
        <a
          href={`tel:${BUSINESS.phoneForTel}`}
          class="contact__phone"
        >
          <div class="icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <g
                id="SVGRepo_bgCarrier"
                stroke-width="0"
              >
              </g>
              <g
                id="SVGRepo_tracerCarrier"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
              </g>
              <g id="SVGRepo_iconCarrier">
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M5.73268 2.043C6.95002 0.832583 8.95439 1.04804 9.9737 2.40962L11.2347 4.09402C12.0641 5.20191 11.9909 6.75032 11.0064 7.72923L10.7676 7.96665C10.7572 7.99694 10.7319 8.09215 10.76 8.2731C10.8232 8.6806 11.1635 9.545 12.592 10.9654C14.02 12.3853 14.8905 12.7253 15.3038 12.7887C15.4911 12.8174 15.5891 12.7906 15.6194 12.78L16.0274 12.3743C16.9026 11.5041 18.2475 11.3414 19.3311 11.9305L21.2416 12.9691C22.8775 13.8584 23.2909 16.0821 21.9505 17.4148L20.53 18.8273C20.0824 19.2723 19.4805 19.6434 18.7459 19.7119C16.9369 19.8806 12.7187 19.6654 8.28659 15.2584C4.14868 11.144 3.35462 7.556 3.25415 5.78817L4.00294 5.74562L3.25415 5.78817C3.20335 4.89426 3.62576 4.13796 4.16308 3.60369L5.73268 2.043ZM8.77291 3.30856C8.26628 2.63182 7.322 2.57801 6.79032 3.10668L5.22072 4.66737C4.8908 4.99542 4.73206 5.35695 4.75173 5.70307C4.83156 7.10766 5.47286 10.3453 9.34423 14.1947C13.4057 18.2331 17.1569 18.3536 18.6067 18.2184C18.9029 18.1908 19.1975 18.0369 19.4724 17.7636L20.8929 16.3511C21.4704 15.777 21.343 14.7315 20.5252 14.2869L18.6147 13.2484C18.0871 12.9616 17.469 13.0562 17.085 13.438L16.6296 13.8909L16.1008 13.359C16.6296 13.8909 16.6289 13.8916 16.6282 13.8923L16.6267 13.8937L16.6236 13.8967L16.6171 13.903L16.6025 13.9166C16.592 13.9262 16.5799 13.9367 16.5664 13.948C16.5392 13.9705 16.5058 13.9959 16.4659 14.0227C16.3858 14.0763 16.2801 14.1347 16.1472 14.1841C15.8764 14.285 15.5192 14.3392 15.0764 14.2713C14.2096 14.1384 13.0614 13.5474 11.5344 12.0291C10.0079 10.5113 9.41194 9.36834 9.2777 8.50306C9.20906 8.06061 9.26381 7.70331 9.36594 7.43225C9.41599 7.29941 9.47497 7.19378 9.5291 7.11389C9.5561 7.07405 9.58179 7.04074 9.60446 7.01368C9.6158 7.00015 9.6264 6.98817 9.63604 6.9777L9.64977 6.96312L9.65606 6.95666L9.65905 6.95363L9.66051 6.95217C9.66122 6.95146 9.66194 6.95075 10.1908 7.48258L9.66194 6.95075L9.94875 6.66556C10.3774 6.23939 10.4374 5.53194 10.0339 4.99297L8.77291 3.30856Z"
                  fill="#4e4b66"
                >
                </path>
              </g>
            </svg>
          </div>
          {BUSINESS.phoneFormatted}
        </a>
      </div>
    </div>
    <form
      id="contact-form"
      name="contact"
      method="POST"
      netlify-honeypot="bot-field"
      data-netlify="true"
    >
      <p class="hidden-form-field">
        <label>
          Don’t fill this out if you’re human:
          <input
            name="bot-field"
            type="text"
          />
        </label>
      </p>

      <div class="success-message">
        <div class="title">
          <h2>Message Sent!</h2>
        </div>
        <p>Thanks for completing the form. We'll be in touch soon!</p>
      </div>
      <div class="form-group">
        <label for="name">Name</label>
        <input
          autocomplete="name"
          type="text"
          id="name"
          name="name"
          oninvalid="this.setCustomValidity('This field is required')"
          oninput="this.setCustomValidity('')"
          placeholder="Name"
          required
        />
        <div class="error-message">This field is required</div>
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input
          autocomplete="email"
          type="email"
          id="email"
          name="email"
          oninvalid="
                  this.setCustomValidity('Please enter a valid email')
                "
          oninput="this.setCustomValidity('')"
          placeholder="Email"
          required
        />
        <div class="error-message">Please enter a valid email</div>
      </div>

      <div class="form-group">
        <label for="message">Message</label>
        <textarea
          name="message"
          id="message"
          oninvalid="this.setCustomValidity('This field is required')"
          oninput="this.setCustomValidity('')"
          placeholder="Message"
          required
        >
        </textarea>
        <div class="error-message">This field is required</div>
      </div>

      <button
        class="btn btn--solid"
        type="submit"
      >
        Submit
      </button>
    </form>
  </div>
</section>

<style>
  /* General Form Styles */
  form {
    display: grid;
    grid-template-columns: 1fr;
    position: relative;

    label {
      display: block;
      font: inherit;
      margin-bottom: 0.5rem;
    }

    input,
    textarea {
      cursor: pointer;
      font: inherit;
      width: 100%;
    }

    button {
      justify-content: center;
      cursor: pointer;
      font: inherit;
      justify-self: start;
      min-width: 33%;
    }

    input,
    textarea {
      border-radius: 0.5rem;
      border: 1px solid rgba(26, 26, 26, 0.6);
      color: var(--color-body-text);
      font-size: 1.125rem;
      padding: 0.66667em 1.33334em;
      height: 3rem;

      &:focus-visible {
        outline-color: var(--color-primary);
      }

      &:hover {
        border-color: var(--color-primary);
      }
    }

    textarea {
      height: calc(3lh + 1.4em); /* 3 line heights + vertical padding */
      resize: block;
    }

    .required::after {
      content: " *";
      color: var(--color-primary);
    }

    legend {
      margin-bottom: 1rem;
    }
  }

  .form-group {
    margin-bottom: 1.5rem;
  }
  /* Error state */
  .error-message {
    padding-top: 0.25rem;
    color: var(--fire-brick);
    display: none;
  }

  .form-group:has(input:user-invalid),
  .form-group:has(textarea:user-invalid) {
    input,
    textarea {
      border-color: #c1121f;
    }

    .error-message {
      display: block;
    }
  }

  /* Success Message */
  .success-message {
    position: absolute;
    top: -1rem;
    left: 0;
    right: 0;
    margin: 0 auto;
    width: fit-content;
    background-color: var(--color-secondary);
    border-radius: 0.75rem;
    color: var(--color-body-text-white);
    padding: 1.5rem;
    z-index: 2;
    display: none;

    &.visible {
      display: block;
    }

    .title {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
      h2 {
        color: inherit;
        font-size: 1.125rem;
      }
    }
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, -0.7857rem + 7.619vw, 1.5rem);
    .icon {
      width: 24px;
    }

    a {
      display: flex;
      align-items: center;
      gap: 0.5em;
      width: fit-content;
    }

    a:hover {
      color: var(--color-primary);
    }
  }

  .contact {
    h2 {
      margin: 0;
    }

    .contact__main-content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 2rem;
    }

    form {
      border-radius: 0.5rem;
      box-shadow: rgba(99, 99, 99, 0.2) 0px 2px 8px 0px;
      margin: 0 auto;
      max-width: 500px;
      padding: 2rem 1.5rem;
      width: 100%;
    }
  }

  .hidden-form-field {
    visibility: hidden;
    height: 0;
    position: absolute;
  }

  a {
    color: var(--color-body-text);
    text-decoration: none;
  }

  @media (min-width: 48rem) {
    form {
      gap: 1.5rem 1rem;
      max-width: 650px;
      margin: 0 auto;
    }

    .form-group {
      margin-bottom: 0;
    }
  }

  @media (min-width: 64rem) {
    .contact {
      .container {
        display: grid;
        grid-template-columns: 2fr 3fr;
      }
    }
  }
</style>
